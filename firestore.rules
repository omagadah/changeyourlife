rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ── Helpers ─────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isValidJournalEntry() {
      let data = request.resource.data;
      return data.content is string
        && data.content.size() <= 50000
        && data.emotion in ['joy', 'calm', 'grateful', 'worried', 'sad', 'angry', 'neutral']
        && data.userId == request.auth.uid;
    }

    // L'XP de l'arbre (`tree`) et son miroir legacy (`levels`) sont écrits
    // côté client (projet sur plan Firebase gratuit — Cloud Functions non
    // déployables). On vérifie seulement qu'ils restent des maps bien formées.
    // Les anciens champs plats `xp_*` restent interdits côté client.
    function xpFieldsValid() {
      let d = request.resource.data;
      let changed = d.diff(resource.data).affectedKeys();
      return !changed.hasAny(['xp_body', 'xp_heart', 'xp_etre', 'xp_order', 'xp_mind'])
        && (!('tree' in d) || d.tree is map)
        && (!('levels' in d) || d.levels is map);
    }

    // Bilan hebdomadaire : 4 réflexions (q1..q4) + métadonnées.
    function isValidBilan() {
      let d = request.resource.data;
      return d.q1 is string && d.q1.size() <= 5000
        && d.q2 is string && d.q2.size() <= 5000
        && d.q3 is string && d.q3.size() <= 5000
        && d.q4 is string && d.q4.size() <= 5000
        && d.weekKey is string && d.weekKey.size() <= 10
        && d.savedAt is number;
    }

    // Note Codex utilisateur. Le body peut contenir du HTML escapé côté front
    // mais on borne quand même la taille pour éviter abus / spam Firestore.
    function isValidCodexNote() {
      let d = request.resource.data;
      return d.uid == request.auth.uid
        && d.title is string && d.title.size() > 0 && d.title.size() <= 200
        && d.summary is string && d.summary.size() <= 1000
        && d.cat in ['corps', 'coeur', 'etre', 'ordre']
        && (!('body' in d) || d.body == null || (d.body is string && d.body.size() <= 20000))
        && (!('tagline' in d) || (d.tagline is string && d.tagline.size() <= 1000))
        && (!('tags' in d) || (d.tags is list && d.tags.size() <= 20));
    }

    // ── Collection utilisateurs ─────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId) && xpFieldsValid();
      // (no delete — préférable de garder l'historique)

      match /journal/{entryId} {
        allow read:   if isSignedIn() && isOwner(userId);
        allow create: if isSignedIn() && isOwner(userId) && isValidJournalEntry();
        allow update: if isSignedIn() && isOwner(userId) && isValidJournalEntry();
        allow delete: if isSignedIn() && isOwner(userId);
      }

      match /moods/{dateStr} {
        allow read:  if isSignedIn() && isOwner(userId);
        allow write: if isSignedIn() && isOwner(userId)
          && request.resource.data.mood is int
          && request.resource.data.mood >= 1
          && request.resource.data.mood <= 5;
      }

      match /bilans/{weekKey} {
        allow read:  if isSignedIn() && isOwner(userId);
        allow write: if isSignedIn() && isOwner(userId) && isValidBilan();
      }

      match /sleep/{dateStr} {
        allow read:  if isSignedIn() && isOwner(userId);
        allow write: if isSignedIn() && isOwner(userId)
          && request.resource.data.quality is int
          && request.resource.data.quality >= 1
          && request.resource.data.quality <= 5;
      }

      match /gratitude/{dateStr} {
        allow read:  if isSignedIn() && isOwner(userId);
        allow write: if isSignedIn() && isOwner(userId)
          && request.resource.data.g1 is string && request.resource.data.g1.size() <= 2000
          && request.resource.data.g2 is string && request.resource.data.g2.size() <= 2000
          && request.resource.data.g3 is string && request.resource.data.g3.size() <= 2000;
      }
    }

    // ── Autoévaluations (Roue de Vie) ──────────────────────────────────────
    match /assessments/{docId} {
      allow read:   if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ── Codex — notes personnelles ─────────────────────────────────────────
    match /codexNotes/{docId} {
      allow read:   if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && isValidCodexNote();
      allow update: if isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && isValidCodexNote();
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ── Collections backend-only (admin SDK exclusif) ──────────────────────
    // OTP de vérification email
    match /verificationCodes/{uid} {
      allow read, write: if false;
    }
    // Rate-limit IA Coach (api/coach.js)
    match /coachRate/{uid} {
      allow read, write: if false;
    }
    // Rate-limit SYL chat (api/chat.js)
    match /chatRate/{uid} {
      allow read, write: if false;
    }
    // Rate-limit traduction publique (api/translate.js)
    match /translateRate/{docId} {
      allow read, write: if false;
    }
    // Rôles (modérateur, admin) — réservé Custom Claims serveur
    match /roles/{uid} {
      allow read:  if isSignedIn() && isOwner(uid);
      allow write: if false;
    }

    // Tout le reste est bloqué par défaut
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
